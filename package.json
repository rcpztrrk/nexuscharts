{
  "name": "nexuscharts",
  "version": "1.0.0",
  "description": "Financial charting engine powered by WebAssembly and WebGL 2.0 for high-throughput candlestick rendering in the browser.",
  "main": "./build/nexus-charts.cjs",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build:wasm": "cmd.exe /c \"cd emsdk && emsdk_env.bat && cd .. && emcmake cmake -S . -B build -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build build\"",
    "build:ts": "rollup -c && node scripts/prepare-public-types.mjs",
    "build": "npm run build:wasm && npm run build:ts",
    "dev": "npx serve public",
    "test": "node --experimental-strip-types --test test/core.test.ts",
    "pack:check": "npm pack --dry-run",
    "test:watch": "node --experimental-strip-types --test --watch test/core.test.ts"
  },
  "keywords": [
    "charts",
    "financial-charts",
    "candlestick",
    "webgl",
    "wasm",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "module": "./build/nexus-charts.esm.js",
  "types": "./build/public-types/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/public-types/index.d.ts",
      "import": "./build/nexus-charts.esm.js",
      "require": "./build/nexus-charts.cjs",
      "default": "./build/nexus-charts.esm.js"
    },
    "./wasm/nexuscharts.js": "./build/nexuscharts.js",
    "./wasm/nexuscharts.wasm": "./build/nexuscharts.wasm",
    "./package.json": "./package.json"
  },
  "files": [
    "./build/nexus-charts.cjs",
    "build/nexus-charts.esm.js",
    "build/nexus-charts.umd.js",
    "build/nexuscharts.js",
    "build/nexuscharts.wasm",
    "build/public-types/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcpztrrk/nexuscharts.git"
  },
  "bugs": {
    "url": "https://github.com/rcpztrrk/nexuscharts/issues"
  },
  "homepage": "https://github.com/rcpztrrk/nexuscharts#readme"
}
